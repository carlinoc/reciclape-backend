# =====================================================
# RECICLAPE BACKEND — Variables de Entorno
# =====================================================
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees .env al repositorio.
# =====================================================

# ── Aplicación ─────────────────────────────────────
PORT=3000
NODE_ENV=development   # development | production

# ── Base de Datos (opción A: variables individuales) ─
DB_HOST=localhost
DB_PORT=5432
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME
DB_NAME=DBReciclape

# ── Base de Datos (opción B: URL completa — Supabase/Railway/etc.) ─
# Si se define DATABASE_URL, las variables DB_* de arriba se ignoran.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────
# OBLIGATORIO en producción: mínimo 32 caracteres aleatorios.
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_MINIMUM_32_RANDOM_CHARACTERS

# ── CORS ──────────────────────────────────────────
# URLs del frontend separadas por coma (sin espacios).
# Ejemplo: https://panel.reciclape.pe,https://app.reciclape.pe
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081

# ── Firebase ──────────────────────────────────────
# Ruta al archivo firebase-config.json (service account).
# En producción usar variables individuales en lugar del archivo.
# FIREBASE_CONFIG_PATH=./firebase-config.json
